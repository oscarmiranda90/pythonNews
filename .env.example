# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: https://supabase.com/dashboard/project/<project>/settings/api
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<service_role_key>          # use service_role for backend server, NOT anon

# ── FastAPI Backend ───────────────────────────────────────────────────────────
# The URL the Next.js frontend and telegram bot use to reach the API
BACKEND_URL=http://localhost:8000
# Allowed CORS origins (comma-separated, no trailing slash)
CORS_ORIGINS=http://localhost:3000,https://your-domain.com

# ── Next.js Frontend ──────────────────────────────────────────────────────────
# Must be prefixed NEXT_PUBLIC_ to be available in the browser
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_DASHBOARD_URL=https://your-domain.com
NEXT_PUBLIC_SITE_NAME=My News Pipeline

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Create a bot via @BotFather → get token
TELEGRAM_BOT_TOKEN=123456789:AAXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Your personal chat ID or group ID (use @userinfobot to find it)
TELEGRAM_CHAT_ID=-1001234567890
# Dashboard URL included in the daily message
DASHBOARD_URL=https://your-domain.com

# ── X (Twitter) API ───────────────────────────────────────────────────────────
# OAuth 1.0a credentials from https://developer.twitter.com/en/portal
X_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
X_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
X_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
X_ACCESS_TOKEN_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Bearer token (for read-only calls if needed)
X_BEARER_TOKEN=AAAAAAAAAAAAAAAAAAAAAA...

# ── OpenClaw ──────────────────────────────────────────────────────────────────
# Gateway URL (default: http://localhost:18789)
OPENCLAW_GATEWAY_URL=http://localhost:18789
# hooks.token from ~/.openclaw/openclaw.json
OPENCLAW_HOOKS_TOKEN=<your-hooks-token>
# Agent ID for tweet generation (created with: openclaw agents add social)
OPENCLAW_TWEET_AGENT_ID=social

# ── Fetcher ───────────────────────────────────────────────────────────────────
# Max total items to fetch and store per day (spread across all sources)
FETCH_MAX_ITEMS=20
# Items per individual RSS source (prevents one feed from dominating)
FETCH_MAX_PER_SOURCE=3
# GitHub trending repos to include per run
FETCH_GITHUB_COUNT=5
# Hacker News items to include per run
FETCH_HN_COUNT=4
